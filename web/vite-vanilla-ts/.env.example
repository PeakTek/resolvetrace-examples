# Copy to `.env.local` for local dev (gitignored) or to `.env` next to the
# compose file for Docker. Both are read by the build / dev server.
#
# Endpoint the SDK POSTs events to. Defaults to the resolvetrace-core
# docker-compose port.
VITE_RT_ENDPOINT=http://localhost:4317

# OSS bearer token. Must match the `OSS_API_KEY` env var set on the ingest
# server (see resolvetrace-core's `deploy/docker-compose.yml`).
VITE_RT_API_KEY=replace-me-with-long-random-string
